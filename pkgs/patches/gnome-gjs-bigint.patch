diff --git a/plugins/gobject/ww-shadow-paintable.c b/plugins/gobject/ww-shadow-paintable.c
index f30f1d4..bb741eb 100644
--- a/plugins/gobject/ww-shadow-paintable.c
+++ b/plugins/gobject/ww-shadow-paintable.c
@@ -1,5 +1,6 @@
 #define _GNU_SOURCE
 #include "ww-shadow-paintable.h"
+#include "ww-display.h"
 
 #include <gtk/gtk.h>
 #include <graphene.h>
@@ -352,3 +353,27 @@ ww_shadow_paintable_clear(WwShadowPaintable *self)
     self->have_shadow = FALSE;
     gdk_paintable_invalidate_contents(GDK_PAINTABLE(self));
 }
+
+gboolean
+ww_shadow_paintable_set_shadow_from_display(WwShadowPaintable *self,
+                                            WwDisplay         *display,
+                                            guint              width,
+                                            guint              height,
+                                            guint              fourcc)
+{
+    gint fd;
+    guint n_planes;
+    guint strides[4];
+    guint64 offsets[4];
+    guint64 modifier;
+
+    g_return_val_if_fail(WW_IS_SHADOW_PAINTABLE(self), FALSE);
+    g_return_val_if_fail(display != NULL, FALSE);
+
+    if (!ww_display_get_shadow_export(display, &fd, &n_planes, strides, offsets, &modifier)) {
+        return FALSE;
+    }
+
+    gboolean res = ww_shadow_paintable_set_shadow(self, fd, n_planes, width, height, fourcc, modifier, strides, offsets);
+    return res;
+}
diff --git a/plugins/gobject/ww-shadow-paintable.h b/plugins/gobject/ww-shadow-paintable.h
