@@ -98,6 +98,28 @@ void ww_shadow_paintable_set_config(WwShadowPaintable *self,
  * Release the texture + shadow fd; paintable renders empty until the
  * next set_shadow().
  */
+/* Forward declaration */
+typedef struct _WwDisplay WwDisplay;
+
+/**
+ * ww_shadow_paintable_set_shadow_from_display:
+ * @self: a #WwShadowPaintable
+ * @display: a #WwDisplay
+ * @width: image width in pixels
+ * @height: image height in pixels
+ * @fourcc: DRM fourcc
+ *
+ * Query the shadow descriptor from @display and bind the paintable.
+ * This avoids GJS double-to-uint64 rounding issues on modifiers.
+ *
+ * Returns: TRUE on success
+ */
+gboolean ww_shadow_paintable_set_shadow_from_display(WwShadowPaintable *self,
+                                                     WwDisplay         *display,
+                                                     guint              width,
+                                                     guint              height,
+                                                     guint              fourcc);
+
 void ww_shadow_paintable_clear(WwShadowPaintable *self);
 
 G_END_DECLS
